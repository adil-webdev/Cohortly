<div class="bg-base-100 rounded-lg shadow-sm border border-base-200 overflow-hidden hover:shadow-lg transition-shadow duration-300 group">
  <div class="h-48 bg-gradient-to-br from-indigo-500 to-purple-600 relative">
    <div class="absolute inset-0 bg-black bg-opacity-20 group-hover:bg-opacity-10 transition-all duration-300"></div>
    <div class="absolute top-4 left-4">
      <span class="bg-base-100 text-indigo-600 px-3 py-1 rounded-full text-sm font-medium">Web Development</span>
    </div>
    <div class="absolute bottom-4 left-4 text-white">
      <i class="fas fa-code text-3xl"></i>
    </div>
  </div>
  <div class="p-6">
    <div class="flex items-center justify-between mb-2">
      <span class="text-sm text-indigo-600 font-medium">Beginner</span>
      <div class="flex items-center text-yellow-400">
        <i class="fas fa-star text-sm"></i>
        <span class="text-base-600 text-sm ml-1">4.8 (124)</span>
      </div>
    </div>
    <%= link_to course_path(course.id) do %>
      <h3 class="text-xl font-bold text-base-900 mb-2 group-hover:text-indigo-600 transition-colors"><%= course.title %></h3>
    <% end %>
    <p class="text-base-600 text-sm mb-4">Master JavaScript from basics to advanced concepts including ES6+, async
      programming, and modern frameworks.</p>
    <div class="flex items-center justify-between mb-4">
      <div class="flex items-center text-base-500 text-sm">
        <i class="fas fa-clock mr-2"></i>
        <span>12 weeks</span>
      </div>
      <div class="flex items-center text-base-500 text-sm">
        <i class="fas fa-users mr-2"></i>
        <span>2,341 students</span>
      </div>
    </div>
    <div class="flex items-center justify-between">
      <div class="text-2xl font-bold text-base-900">$99</div>
      <% unless current_user&.enrolled?(course) %>
        <%= button_to "Enroll Now", course_enrollments_path(course.id), method: :post, class: "w-full bg-base-100 text-indigo-600 py-3 px-6 rounded-md font-semibold hover:bg-base-100 transition-colors mb-4" %>
      <% else %>
        <%= button_to "Already Enrolled", false, method: :post, class: "w-full bg-base-100 text-indigo-600 py-3 px-6 rounded-md font-semibold hover:bg-base-100 transition-colors mb-4 disabled:bg-gray-400 disabled:cursor-not-allowed", disabled: true %>
      <% end %>
    </div>
  </div>
</div>
