<div class="lesson-fields lesson-item bg-gray-50 p-4 rounded-md mb-3" data-nested-form-target="template">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Lesson Title</label>
      <%= f.text_field :title, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Lesson title", required: true %>
    </div>
    <div>
      <label class="block text-sm font-medium text-gray-700 mb-1">Lesson Position</label>
      <%= f.number_field :position, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Lesson title", required: true %>
    </div>

    <div class="col-span-2">
      <label class="block text-sm font-medium text-gray-700 mb-1">Lesson Content</label>
      <%= f.text_area :content, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Lesson title", required: true %>
    </div>

    <div class="col-span-2">
      <label class="block text-sm font-medium text-gray-700 mb-1">Lesson Video</label>
      <%= f.file_field :video, class: "w-full px-3 py-2 border border-gray-300 rounded-md focus:outline-none focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500", placeholder: "Lesson Video File" %>
    </div>

