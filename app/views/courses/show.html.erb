
<%= render partial: 'shared/nav', locals: { course: @course } %>

<!-- Course Header -->
<div class="bg-gradient-to-br from-indigo-500 to-purple-600 text-white py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-center">
      <div class="lg:col-span-2">
        <div class="flex items-center mb-4">
          <span class="bg-white text-indigo-600 px-3 py-1 rounded-full text-sm font-medium mr-4">Web Development</span>
          <span class="text-indigo-100">Beginner Level</span>
        </div>
        <h1 class="text-4xl font-bold mb-4">Complete JavaScript Course</h1>
        <p class="text-xl text-indigo-100 mb-6">
          Master JavaScript from basics to advanced concepts including ES6+, async programming, and modern frameworks.
        </p>
        <div class="flex flex-wrap items-center gap-6 text-indigo-100">
          <div class="flex items-center">
            <i class="fas fa-clock mr-2"></i>
            <span>12 weeks</span>
          </div>
          <div class="flex items-center">
            <i class="fas fa-users mr-2"></i>
            <span>2,341 students</span>
          </div>
          <div class="flex items-center">
            <i class="fas fa-star mr-2 text-yellow-300"></i>
            <span>4.8 (124 reviews)</span>
          </div>
          <div class="flex items-center">
            <i class="fas fa-play-circle mr-2"></i>
            <span>45 lessons</span>
          </div>
        </div>
      </div>
      <div class="bg-white/10 backdrop-blur-sm rounded-lg p-6">
        <div class="text-center mb-6">
          <div class="text-3xl font-bold mb-2">$99</div>
          <div class="text-indigo-100">One-time payment</div>
        </div>
        <%# if current_user.enrolled?(@course) %>
        <%#=  button_to "Already Enrolled", false, method: :post, class: "w-full bg-white text-indigo-600 py-3 px-6 rounded-md font-semibold hover:bg-gray-100 transition-colors mb-4 disabled:bg-gray-400 disabled:cursor-not-allowed", disabled: true %>
        <%#  else  %>
        <%#= button_to "Enroll Now", enroll_course_path(@course.id), method: :post, class: "w-full bg-white text-indigo-600 py-3 px-6 rounded-md font-semibold hover:bg-gray-100 transition-colors mb-4" %>
        <%#  end %>
        <% unless current_user&.enrolled?(@course) %>
          <%= button_to "Enroll Now", course_enrollments_path(@course.id), method: :post, class: "w-full bg-white text-indigo-600 py-3 px-6 rounded-md font-semibold hover:bg-gray-100 transition-colors mb-4" %>
        <% else %>
          <%= button_to "Already Enrolled", false, method: :post, class: "w-full bg-white text-indigo-600 py-3 px-6 rounded-md font-semibold hover:bg-gray-100 transition-colors mb-4 disabled:bg-gray-400 disabled:cursor-not-allowed", disabled: true %>
        <% end %>
        <div class="text-center text-sm text-indigo-100">
          <p class="mb-2">✓ Lifetime access</p>
          <p class="mb-2">✓ Certificate of completion</p>
          <p>✓ 30-day money-back guarantee</p>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Course Content -->
<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-12">
  <div class="grid grid-cols-1 lg:grid-cols-3 gap-8">
    <!-- Main Content -->
    <div class="lg:col-span-2">
      <!-- Course Description -->
      <div class="bg-base-100 rounded-lg shadow-sm border border-base-200 p-6 mb-8">
        <h2 class="text-2xl font-bold text-base-900 mb-4">About This Course</h2>
        <div class="prose text-base-600">
          <p class="mb-4">
            This comprehensive JavaScript course is designed to take you from a complete beginner to an advanced
            JavaScript developer.
            You'll learn everything you need to know to build modern, interactive web applications.
          </p>
          <p class="mb-4">
            The course covers fundamental programming concepts, modern ES6+ features, DOM manipulation, asynchronous
            programming,
            and popular frameworks. Each lesson includes hands-on exercises and real-world projects.
          </p>
          <h3 class="text-lg font-semibold text-base-900 mb-2">What You'll Learn:</h3>
          <ul class="list-disc pl-6 space-y-1">
            <li>JavaScript fundamentals and syntax</li>
            <li>ES6+ features and modern JavaScript</li>
            <li>DOM manipulation and event handling</li>
            <li>Asynchronous programming with Promises and async/await</li>
            <li>Working with APIs and AJAX</li>
            <li>Object-oriented programming in JavaScript</li>
            <li>Popular frameworks and libraries</li>
            <li>Best practices and debugging techniques</li>
          </ul>
        </div>
      </div>

      <!-- Course Curriculum -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <div class="flex justify-between items-center mb-6">
          <h2 class="text-2xl font-bold text-gray-900">Course Curriculum</h2>
          <div class="text-sm text-gray-500">
            8 sections • 45 lessons • 24h total length
          </div>
        </div>

        <%= render @course.sections %>


        <!-- More sections would continue here -->
        <div class="text-center py-4">
          <p class="text-gray-500 text-sm mb-4">
<!--            5 more sections available after enrollment-->
          </p>
          <!--          <button class="">-->
          <!--            Enroll to See Full Curriculum-->
          <!--          </button>-->
          <% if current_user&.enrolled?(@course) || current_user&.is_the_creator?(@course) %>
            <%= link_to 'Watch the Course', watch_course_path, class: "bg-indigo-600 text-white px-6 py-2 rounded-md font-medium hover:bg-indigo-700 transition-colors" %>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Sidebar -->
    <div class="space-y-6">
      <!-- Instructor -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Your Instructor</h3>
        <div class="flex items-center mb-4">
          <div class="w-16 h-16 bg-indigo-100 rounded-full flex items-center justify-center mr-4">
            <span class="text-indigo-600 font-bold text-xl">JS</span>
          </div>
          <div>
            <h4 class="font-semibold text-gray-900">John Smith</h4>
            <p class="text-sm text-gray-600">Senior JavaScript Developer</p>
          </div>
        </div>
        <p class="text-sm text-gray-600 mb-4">
          John has 8+ years of experience in web development and has taught over 50,000 students worldwide.
        </p>
        <div class="flex items-center text-sm text-gray-500 space-x-4">
          <div class="flex items-center">
            <i class="fas fa-star text-yellow-400 mr-1"></i>
            <span>4.9 rating</span>
          </div>
          <div class="flex items-center">
            <i class="fas fa-users mr-1"></i>
            <span>52K students</span>
          </div>
        </div>
      </div>

      <!-- Course Features -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">This Course Includes</h3>
        <ul class="space-y-3">
          <li class="flex items-center text-sm text-gray-600">
            <i class="fas fa-play-circle text-indigo-600 mr-3"></i>
            24 hours on-demand video
          </li>
          <li class="flex items-center text-sm text-gray-600">
            <i class="fas fa-file-alt text-indigo-600 mr-3"></i>
            15 coding exercises
          </li>
          <li class="flex items-center text-sm text-gray-600">
            <i class="fas fa-download text-indigo-600 mr-3"></i>
            Downloadable resources
          </li>
          <li class="flex items-center text-sm text-gray-600">
            <i class="fas fa-infinity text-indigo-600 mr-3"></i>
            Full lifetime access
          </li>
          <li class="flex items-center text-sm text-gray-600">
            <i class="fas fa-mobile-alt text-indigo-600 mr-3"></i>
            Access on mobile and TV
          </li>
          <li class="flex items-center text-sm text-gray-600">
            <i class="fas fa-certificate text-indigo-600 mr-3"></i>
            Certificate of completion
          </li>
        </ul>
      </div>

      <!-- Related Courses -->
      <div class="bg-white rounded-lg shadow-sm border border-gray-200 p-6">
        <h3 class="text-lg font-semibold text-gray-900 mb-4">Related Courses</h3>
        <div class="space-y-4">
          <div class="flex items-center space-x-3">
            <div class="w-12 h-12 bg-blue-100 rounded flex items-center justify-center">
              <i class="fab fa-react text-blue-600"></i>
            </div>
            <div class="flex-1">
              <h4 class="text-sm font-medium text-gray-900">React Development</h4>
              <p class="text-xs text-gray-500">$149</p>
            </div>
          </div>
          <div class="flex items-center space-x-3">
            <div class="w-12 h-12 bg-green-100 rounded flex items-center justify-center">
              <i class="fab fa-node-js text-green-600"></i>
            </div>
            <div class="flex-1">
              <h4 class="text-sm font-medium text-gray-900">Node.js Backend</h4>
              <p class="text-xs text-gray-500">$129</p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>

<!-- Preview Modal -->
<div id="preview-modal" class="hidden fixed inset-0 bg-black bg-opacity-50 flex items-center justify-center z-50">
  <div class="bg-white rounded-lg max-w-2xl w-full mx-4 max-h-96 overflow-y-auto">
    <div class="p-6">
      <div class="flex justify-between items-center mb-4">
        <h3 id="preview-title" class="text-xl font-semibold text-gray-900"></h3>
        <button onclick="togglePreview()" class="text-gray-400 hover:text-gray-600">
          <i class="fas fa-times text-xl"></i>
        </button>
      </div>
      <div class="bg-gray-100 rounded-lg p-4 mb-4">
        <div class="flex items-center justify-center h-48 text-gray-500">
          <i class="fas fa-play-circle text-6xl"></i>
        </div>
      </div>
      <p id="preview-content" class="text-gray-600 mb-4"></p>
      <div class="flex justify-end space-x-3">
        <button onclick="togglePreview()" class="px-4 py-2 text-gray-600 hover:text-gray-800 transition-colors">
          Close
        </button>
        <button class="bg-indigo-600 text-white px-6 py-2 rounded-md font-medium hover:bg-indigo-700 transition-colors">
          Enroll to Continue
        </button>
      </div>
    </div>
  </div>
</div>

<!-- Footer -->

<%= render 'shared/footer' %>