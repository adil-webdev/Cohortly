<div class="min-h-screen bg-base-100">
  <!-- Header -->
  <div class="navbar bg-base-100 border-b border-base-300">
    <div class="navbar-start">
      <%= link_to root_path, class: "btn btn-ghost text-xl text-primary" do %>
        Cohortly
      <% end %>
      
      <!-- Breadcrumb -->
      <div class="breadcrumbs text-sm ml-4">
        <ul>
          <li><%= link_to "My Courses", courses_path, class: "link link-hover" %></li>
          <li><%= @course.title %></li>
        </ul>
      </div>
    </div>

    <div class="navbar-end">
      <!-- Progress -->
      <% unless current_user == @course.instructor %>
        <div class="flex items-center gap-3 mr-4">
          <span class="text-sm opacity-70">Progress:</span>
          <progress class="progress progress-primary w-32" value="<%= @course.progress_for_user(current_user) %>" max="100"></progress>
          <span class="text-sm font-medium"><%= @course.progress_for_user(current_user) %>%</span>
        </div>
      <% end %>

      <!-- Theme Toggle -->
      <label class="swap swap-rotate mr-4">
        <input type="checkbox" class="theme-controller" value="dark" />
        <svg class="swap-off fill-current w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M5.64,17l-.71.71a1,1,0,0,0,0,1.41,1,1,0,0,0,1.41,0l.71-.71A1,1,0,0,0,5.64,17ZM5,12a1,1,0,0,0-1-1H3a1,1,0,0,0,0,2H4A1,1,0,0,0,5,12Zm7-7a1,1,0,0,0,1-1V3a1,1,0,0,0-2,0V4A1,1,0,0,0,12,5ZM5.64,7.05a1,1,0,0,0,.7.29,1,1,0,0,0,.71-.29,1,1,0,0,0,0-1.41l-.71-.71A1,1,0,0,0,4.93,6.34Zm12,.29a1,1,0,0,0,.7-.29l.71-.71a1,1,0,1,0-1.41-1.41L17,5.64a1,1,0,0,0,0,1.41A1,1,0,0,0,17.66,7.34ZM21,11H20a1,1,0,0,0,0,2h1a1,1,0,0,0,0-2Zm-9,8a1,1,0,0,0-1,1v1a1,1,0,0,0,2,0V20A1,1,0,0,0,12,19ZM18.36,17A1,1,0,0,0,17,18.36l.71.71a1,1,0,0,0,1.41,0,1,1,0,0,0,0-1.41ZM12,6.5A5.5,5.5,0,1,0,17.5,12,5.51,5.51,0,0,0,12,6.5Zm0,9A3.5,3.5,0,1,1,15.5,12,3.5,3.5,0,0,1,12,15.5Z"/>
        </svg>
        <svg class="swap-on fill-current w-6 h-6" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
          <path d="M21.64,13a1,1,0,0,0-1.05-.14,8.05,8.05,0,0,1-3.37.73A8.15,8.15,0,0,1,9.08,5.49a8.59,8.59,0,0,1,.25-2A1,1,0,0,0,8,2.36,10.14,10.14,0,1,0,22,14.05,1,1,0,0,0,21.64,13Zm-9.5,6.69A8.14,8.14,0,0,1,7.08,5.22v.27A10.15,10.15,0,0,0,17.22,15.63a9.79,9.79,0,0,0,2.1-.22A8.11,8.11,0,0,1,12.14,19.73Z"/>
        </svg>
      </label>

      <!-- User dropdown -->
      <div class="dropdown dropdown-end">
        <div tabindex="0" role="button" class="btn btn-ghost btn-circle avatar">
          <div class="w-10 rounded-full bg-primary text-primary-content flex items-center justify-center">
            <span class="text-sm font-medium">
              <%= current_user.firstname&.first&.upcase || current_user.email.first.upcase %>
            </span>
          </div>
        </div>
        <ul tabindex="0" class="menu menu-sm dropdown-content mt-3 z-[1] p-2 shadow bg-base-100 rounded-box w-52">
          <li><%= link_to "Dashboard", dashboard_path %></li>
          <li><%= link_to "My Courses", courses_path %></li>
          <li><a>Sign out</a></li>
        </ul>
      </div>
    </div>
  </div>

  <!-- Main Content -->
  <div class="flex min-h-screen">
    <!-- Main Video and Content Area -->
    <div class="flex-1 flex flex-col">
      <!-- Video Player Section -->
      <turbo-frame id="lesson-content">
        <div class="bg-black">
          <div class="aspect-video">
            <% if @lesson&.video&.attached? %>
              <video controls class="w-full h-full">
                <source src="<%= url_for(@lesson.video) %>" type="<%= @lesson.video.content_type %>" />
                Your browser does not support the video tag.
              </video>
            <% else %>
              <div class="w-full h-full flex items-center justify-center bg-base-200">
                <div class="text-center">
                  <div class="text-4xl mb-4">📹</div>
                  <p class="text-lg opacity-70">No video available for this lesson</p>
                </div>
              </div>
            <% end %>
          </div>
        </div>

        <!-- Lesson Content -->
        <div class="p-6 bg-base-100">
          <!-- Lesson Header -->
          <div class="card bg-base-100 shadow-xl border border-base-300 mb-6">
            <div class="card-body">
              <div class="flex items-center justify-between mb-4">
                <h2 class="card-title text-2xl">
                  <%= @lesson&.title || "Select a lesson" %>
                </h2>
                <div class="flex gap-2">
                  <button class="btn btn-ghost btn-sm">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4.318 6.318a4.5 4.5 0 000 6.364L12 20.364l7.682-7.682a4.5 4.5 0 00-6.364-6.364L12 7.636l-1.318-1.318a4.5 4.5 0 00-6.364 0z"></path>
                    </svg>
                  </button>
                  <button class="btn btn-ghost btn-sm">
                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"></path>
                    </svg>
                  </button>
                </div>
              </div>

              <% if @lesson&.content %>
                <p class="opacity-70 mb-4"><%= @lesson.content %></p>
              <% end %>

              <div class="grid grid-cols-1 md:grid-cols-3 gap-4">
                <div class="stat bg-base-200 rounded-lg">
                  <div class="stat-figure text-primary">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                    </svg>
                  </div>
                  <div class="stat-title">Duration</div>
                  <div class="stat-value text-lg">45 min</div>
                </div>

                <div class="stat bg-base-200 rounded-lg">
                  <div class="stat-figure text-secondary">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"></path>
                    </svg>
                  </div>
                  <div class="stat-title">Resources</div>
                  <div class="stat-value text-lg">5 files</div>
                </div>

                <div class="stat bg-base-200 rounded-lg">
                  <div class="stat-figure text-accent">
                    <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v10a2 2 0 002 2h8a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"></path>
                    </svg>
                  </div>
                  <div class="stat-title">Assignment</div>
                  <div class="stat-value text-lg">Due 3d</div>
                </div>
              </div>
            </div>
          </div>

          <!-- Comments Section -->
          <div class="card bg-base-100 shadow-xl border border-base-300">
            <div class="card-body">
              <div class="flex items-center justify-between mb-6">
                <h3 class="card-title">Discussion (12)</h3>
                <button class="btn btn-primary btn-sm">Ask Question</button>
              </div>

              <!-- Comment Form -->
              <div class="mb-6">
                <div class="flex gap-3">
                  <div class="avatar">
                    <div class="w-10 rounded-full bg-primary text-primary-content flex items-center justify-center">
                      <span class="text-sm font-medium">
                        <%= current_user.firstname&.first&.upcase || current_user.email.first.upcase %>
                      </span>
                    </div>
                  </div>
                  <div class="flex-1">
                    <textarea 
                      class="textarea textarea-bordered w-full" 
                      placeholder="Add a comment or ask a question..."
                      rows="3"></textarea>
                    <div class="mt-2 flex justify-end">
                      <button class="btn btn-primary btn-sm">Post Comment</button>
                    </div>
                  </div>
                </div>
              </div>

              <!-- Comments List -->
              <div class="space-y-4">
                <!-- Comment 1 -->
                <div class="chat chat-start">
                  <div class="chat-image avatar">
                    <div class="w-10 rounded-full bg-info text-info-content flex items-center justify-center">
                      <span class="text-sm font-medium">JS</span>
                    </div>
                  </div>
                  <div class="chat-header">
                    John Smith
                    <time class="text-xs opacity-50">2 hours ago</time>
                  </div>
                  <div class="chat-bubble">
                    Great explanation of the matplotlib customization! Could you show how to add custom color palettes to the seaborn plots?
                  </div>
                  <div class="chat-footer opacity-50">
                    <button class="btn btn-ghost btn-xs">Reply</button>
                    <button class="btn btn-ghost btn-xs">Like (3)</button>
                  </div>
                </div>

                <!-- Comment 2 -->
                <div class="chat chat-start">
                  <div class="chat-image avatar">
                    <div class="w-10 rounded-full bg-success text-success-content flex items-center justify-center">
                      <span class="text-sm font-medium">DJ</span>
                    </div>
                  </div>
                  <div class="chat-header">
                    Dr. Johnson
                    <div class="badge badge-primary badge-sm">Instructor</div>
                    <time class="text-xs opacity-50">1 hour ago</time>
                  </div>
                  <div class="chat-bubble">
                    @John Smith Great question! I'll cover custom color palettes in the next video. For now, you can check out the seaborn documentation on color palettes.
                  </div>
                  <div class="chat-footer opacity-50">
                    <button class="btn btn-ghost btn-xs">Reply</button>
                    <button class="btn btn-ghost btn-xs">Like (8)</button>
                  </div>
                </div>
              </div>

              <div class="mt-6 text-center">
                <button class="btn btn-ghost btn-sm">Load more comments</button>
              </div>
            </div>
          </div>
        </div>
      </turbo-frame>
    </div>

    <!-- Sidebar -->
    <div class="w-80 bg-base-100 border-l border-base-300 overflow-y-auto">
      <div class="p-4">
        <div class="flex items-center justify-between mb-4">
          <h3 class="text-lg font-semibold">Course Content</h3>
          <button class="btn btn-ghost btn-sm" onclick="toggleSidebar()">
            <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"></path>
            </svg>
          </button>
        </div>

        <!-- Course Progress -->
        <% unless current_user == @course.instructor %>
          <div class="mb-6">
            <div class="flex items-center justify-between text-sm mb-2">
              <span class="opacity-70">Overall Progress</span>
              <span class="font-medium"><%= @course.progress_for_user(current_user) %>%</span>
            </div>
            <progress class="progress progress-primary w-full" value="<%= @course.progress_for_user(current_user) %>" max="100"></progress>
          </div>
        <% end %>

        <!-- Course Sections -->
        <div class="space-y-4">
          <%= render @course.sections %>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  function toggleSidebar() {
    const sidebar = document.querySelector('.w-80');
    sidebar.classList.toggle('hidden');
  }

  // Theme toggle functionality
  document.addEventListener('DOMContentLoaded', function() {
    const themeToggle = document.querySelector('.theme-controller');
    const currentTheme = localStorage.getItem('theme') || 'light';
    
    document.documentElement.setAttribute('data-theme', currentTheme);
    if (currentTheme === 'dark') {
      themeToggle.checked = true;
    }
    
    themeToggle.addEventListener('change', function() {
      const theme = this.checked ? 'dark' : 'light';
      document.documentElement.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
    });
  });
</script>