<!-- Get Started Section -->
<div id="get-started" class="bg-gray-50 py-16">
  <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="text-center">
      <h2 class="text-3xl font-extrabold text-gray-900 sm:text-4xl">
        Choose Your Learning Path
      </h2>
      <p class="mt-4 text-xl text-gray-600">
        Join thousands of learners and educators already using Cohortly
      </p>
    </div>

    <div class="mt-12 grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-2 max-w-4xl mx-auto">
      <!-- Student Card -->
      <div class="relative bg-white rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition-shadow duration-300">
        <div class="px-6 py-8">
          <div class="flex items-center justify-center w-16 h-16 bg-blue-100 rounded-full mx-auto mb-6">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 text-center mb-4">I'm a Student</h3>
          <p class="text-gray-600 text-center mb-6">
            Access courses, submit assignments, track your progress, and collaborate with classmates.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-center text-sm text-gray-600">
              <svg class="w-4 h-4 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Access to all course materials
            </li>
            <li class="flex items-center text-sm text-gray-600">
              <svg class="w-4 h-4 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Assignment submission system
            </li>
            <li class="flex items-center text-sm text-gray-600">
              <svg class="w-4 h-4 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Progress tracking & grades
            </li>
            <li class="flex items-center text-sm text-gray-600">
              <svg class="w-4 h-4 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Discussion forums
            </li>
          </ul>
          <%= link_to "Sign Up as Student", new_user_registration_path(role: "student"), class: "w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-150 ease-in-out text-center block" %>
          <p class="text-center text-sm text-gray-500 mt-4">
            Already have an account?
            <%= link_to "Sign in", new_user_session_path , class: "text-blue-600 hover:text-blue-500 font-medium" %>
<!--            <a href="/login" class="">Sign in</a>-->
          </p>
        </div>
      </div>

      <!-- Teacher Card -->
      <div class="relative bg-white rounded-2xl shadow-xl overflow-hidden hover:shadow-2xl transition-shadow duration-300">
        <div class="px-6 py-8">
          <div class="flex items-center justify-center w-16 h-16 bg-indigo-100 rounded-full mx-auto mb-6">
            <svg class="w-8 h-8 text-indigo-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
            </svg>
          </div>
          <h3 class="text-2xl font-bold text-gray-900 text-center mb-4">I'm a Teacher</h3>
          <p class="text-gray-600 text-center mb-6">
            Create courses, manage students, grade assignments, and track class performance.
          </p>
          <ul class="space-y-3 mb-8">
            <li class="flex items-center text-sm text-gray-600">
              <svg class="w-4 h-4 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Course creation & management
            </li>
            <li class="flex items-center text-sm text-gray-600">
              <svg class="w-4 h-4 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Student enrollment system
            </li>
            <li class="flex items-center text-sm text-gray-600">
              <svg class="w-4 h-4 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Grading & feedback tools
            </li>
            <li class="flex items-center text-sm text-gray-600">
              <svg class="w-4 h-4 text-green-500 mr-3" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
              </svg>
              Analytics & reporting
            </li>
          </ul>
<!--          <a href="/signup?role=instructor" class="">-->
<!--            Sign Up as Teacher-->
<!--          </a>-->
          <%= link_to "Sign Up as Instructor", new_user_registration_path(role: "instructor"), class: "w-full bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-150 ease-in-out text-center block" %>
          <p class="text-center text-sm text-gray-500 mt-4">
            Already have an account?
            <%= link_to "Sign in", new_user_session_path, class: "text-indigo-600 hover:text-indigo-500 font-medium" %>
<!--            <a href="/login" class="">Sign in</a>-->
          </p>
        </div>
      </div>
    </div>
  </div>
</div>

