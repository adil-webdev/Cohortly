<% @enrolled_courses.each do |course| %>
  <div class="bg-base-100 overflow-hidden shadow rounded-lg hover:shadow-lg transition-shadow duration-300">
    <div class="h-48 bg-gradient-to-r from-blue-500 to-blue-600 flex items-center justify-center relative">
      <svg class="h-16 w-16 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 19v-6a2 2 0 00-2-2H5a2 2 0 00-2 2v6a2 2 0 002 2h2a2 2 0 002-2zm0 0V9a2 2 0 012-2h2a2 2 0 012 2v10m-6 0a2 2 0 002 2h2a2 2 0 002-2m0 0V5a2 2 0 012-2h2a2 2 0 012 2v4a2 2 0 01-2 2h-2a2 2 0 01-2-2z"></path>
      </svg>
      <span class="absolute top-4 right-4 inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-yellow-100 text-yellow-800">
              In Progress
            </span>
    </div>
    <div class="p-6">
      <div class="flex items-center justify-between mb-2">
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium bg-info-content text-info">
                Data Science
              </span>
        <span class="text-sm text-gray-500">12 weeks</span>
      </div>
      <h3 class="text-lg font-semibold text-base-900 mb-2"><%= course.title %></h3>
      <p class="text-base-600 text-sm mb-4">
        Learn the fundamentals of data analysis, visualization, and machine learning with Python.
      </p>

      <!-- Progress Bar -->
      <div class="mb-4">
        <div class="flex items-center justify-between text-sm mb-1">
          <span class="text-base-600">Progress</span>
          <span class="font-medium text-base-900">75%</span>
        </div>
        <div class="w-full bg-gray-200 rounded-full h-2">
          <div class="bg-blue-600 h-2 rounded-full" style="width: 75%"></div>
        </div>
      </div>

      <!-- Course Info -->
      <div class="flex items-center justify-between mb-4 text-sm text-base-600">
        <div class="flex items-center">
          <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
          </svg>
          Dr. Johnson
        </div>
        <div class="flex items-center">
          <svg class="h-4 w-4 mr-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
          </svg>
          Next: Module 8
        </div>
      </div>

      <div class="flex space-x-3">
        <%= link_to course_path(course.id), class: "flex-1 bg-indigo-600 hover:bg-indigo-700 text-white text-center py-2 px-4 rounded-md text-sm font-medium transition duration-150 ease-in-out" do %>
          Continue Learning
        <% end %>
        <%= link_to "#", class: "flex-shrink-0 bg-base-200 hover:bg-base-300 text-base-700 py-2 px-3 rounded-md text-sm transition duration-150 ease-in-out" do %>
          <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8.684 13.342C8.886 12.938 9 12.482 9 12c0-.482-.114-.938-.316-1.342m0 2.684a3 3 0 110-2.684m0 2.684l6.632 3.316m-6.632-6l6.632-3.316m0 0a3 3 0 105.367-2.684 3 3 0 00-5.367 2.684zm0 9.316a3 3 0 105.367 2.684 3 3 0 00-5.367-2.684z"></path>
          </svg>
        <% end %>
      </div>
    </div>
  </div>
<% end %>