<div class="min-h-screen flex items-center justify-center bg-base-50 py-12 px-4 sm:px-6 lg:px-8">
  <div class="max-w-md w-full space-y-8">
    <div>
      <div class="mx-auto h-12 w-auto flex justify-center">
        <h1 class="text-3xl font-bold text-indigo-600">Cohortly</h1>
      </div>
      <h2 class="mt-6 text-center text-3xl font-extrabold text-base-900">
        Create your account
      </h2>
      <p class="mt-2 text-center text-sm text-base-600">
        Or
        <%= link_to "sign in to existing account", new_user_session_path, class: "font-medium text-indigo-600 hover:text-indigo-500" %>
      </p>
    </div>

    <%= form_for(resource, as: resource_name, url: registration_path(resource_name)) do |f| %>
      <div class="space-y-4">
        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :first_name, "First name", class: "block text-sm font-medium text-base-700" %>
            <%= f.text_field :firstname, class: "mt-1 appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: "First name", required: true %>
          </div>
          <div>
            <%= f.label :last_name, "Last name", class: "block text-sm font-medium text-base-700" %>
            <%= f.text_field :lastname, class: "mt-1 appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: "Last name", required: true %>
          </div>
        </div>

        <div class="grid grid-cols-2 gap-4">
          <div>
            <%= f.label :age, "Age", class: "block text-sm font-medium text-base-700" %>
            <%= f.number_field :age, min: 0, max: 100, class: "mt-1 appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: "Age", required: true %>
          </div>
          <div>
            <%= f.label :gender, "Gender", class: "block text-sm font-medium text-base-700" %>
            <%= f.select :gender, options_for_select([["Male", "male"], ["Female", "female"]]), { prompt: 'Select your gender' }, class: "mt-1 block w-full px-3 py-2 bg-base-100 text-base-content border border-gray-300 rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
          </div>
        </div>

        <div>
          <%= f.label :email, "Email address", class: "block text-sm font-medium text-base-700" %>
          <%= f.email_field :email, class: "mt-1 appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: "Email address", required: true %>
        </div>


        <div>
          <%= f.label :password, "Password", class: "block text-sm font-medium text-base-700" %>
          <%= f.password_field :password, class: "mt-1 appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: "Password (min. 8 characters)", required: true, minlength: 8 %>
        </div>

        <div>
          <%= f.label :password_confirmation, "Confirm Password", class: "block text-sm font-medium text-base-700" %>
          <%= f.password_field :password_confirmation, class: "mt-1 appearance-none relative block w-full px-3 py-2 border border-gray-300 placeholder-gray-500 text-gray-900 rounded-md focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm", placeholder: "Confirm password", required: true %>
        </div>

<!--        <div>-->
          <%#= f.label :role, "I am a:", class: "block text-sm font-medium text-gray-700" %>
          <%#= f.select :role, options_for_select([["Student", "student"], ["Instructor", "instructor"], ["Administrator", "admin"]]), { prompt: 'Select your role' }, class: "mt-1 block w-full px-3 py-2 border border-gray-300 bg-white rounded-md shadow-sm focus:outline-none focus:ring-indigo-500 focus:border-indigo-500 sm:text-sm" %>
<!--        </div>-->
        <%= f.hidden_field :role, value: @role || "student" %>

<!--        <div class="flex items-center">-->
<!--          <input type="checkbox" class="h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded" required />-->
          <%#= f.check_box :terms_accepted, class: "h-4 w-4 text-indigo-600 focus:ring-indigo-500 border-gray-300 rounded", required: true %>
          <%#= f.label :terms_accepted, class: "ml-2 block text-sm text-gray-900" do %>
<!--            I agree to the terms of service-->
            <%#= link_to "Terms of Service", terms_path, class: "text-indigo-600 hover:text-indigo-500", target: "_blank" %>
<!--            and-->
            <%#= link_to "Privacy Policy", privacy_path, class: "text-indigo-600 hover:text-indigo-500", target: "_blank" %>
          <%# end %>
<!--        </div>-->

        <div>
          <%= f.submit "Create Account", class: "group relative w-full flex justify-center py-2 px-4 border border-transparent text-sm font-medium rounded-md text-white bg-indigo-600 hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition duration-150 ease-in-out" %>
        </div>

        <% if resource.errors.any? %>
          <div class="rounded-md bg-red-50 p-4">
            <div class="flex">
              <div class="ml-3">
                <h3 class="text-sm font-medium text-red-800">Please fix the following errors:</h3>
                <ul class="mt-2 text-sm text-red-700 list-disc pl-5 space-y-1">
                  <% resource.errors.full_messages.each do |message| %>
                    <li><%= message %></li>
                  <% end %>
                </ul>
              </div>
            </div>
          </div>
        <% end %>
      </div>
    <% end %>
  </div>
</div>